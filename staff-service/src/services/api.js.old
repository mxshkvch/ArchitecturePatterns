// Это главный файл API, который экспортирует все необходимые функции

// Простой TokenManager для работы с токенами
class TokenManager {
  getToken() {
    return localStorage.getItem('access_token');
  }
  
  setToken(token) {
    localStorage.setItem('access_token', token);
  }
  
  getRole() {
    return localStorage.getItem('user_role');
  }
  
  setRole(role) {
    localStorage.setItem('user_role', role);
  }
  
  isAuthenticated() {
    const token = this.getToken();
    const role = this.getRole();
    return !!(token && role === 'staff');
  }
  
  clear() {
    localStorage.removeItem('access_token');
    localStorage.removeItem('user_role');
    localStorage.removeItem('user_email');
    localStorage.removeItem('user_id');
    localStorage.removeItem('user');
  }
}

const tokenManager = new TokenManager();

// Auth Service
const authService = {
  logout() {
    console.log('🚪 Logging out...');
    tokenManager.clear();
    window.location.href = 'http://localhost:5175/login';
  },
  
  initialize() {
    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');
    const role = urlParams.get('role');
    
    if (token && role === 'staff') {
      console.log('✅ Token found in URL, saving...');
      tokenManager.setToken(token);
      tokenManager.setRole(role);
      
      try {
        const base64Url = token.split('.')[1];
        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
        const payload = JSON.parse(atob(base64));
        
        if (payload.email) localStorage.setItem('user_email', payload.email);
        if (payload.nameid) localStorage.setItem('user_id', payload.nameid);
        
        const user = {
          id: payload.nameid,
          email: payload.email,
          role: payload.role
        };
        localStorage.setItem('user', JSON.stringify(user));
      } catch (e) {
        console.error('Failed to decode token:', e);
      }
      
      window.history.replaceState({}, document.title, window.location.pathname);
      return true;
    }
    
    return false;
  },
  
  isAuthenticated() {
    return tokenManager.isAuthenticated();
  },
  
  getToken() {
    return tokenManager.getToken();
  }
};

